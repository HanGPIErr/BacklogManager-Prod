<Window x:Class="BacklogManager.Views.EquipeEditionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:BacklogManager.Services"
        Title="Équipe" Height="700" Width="650"
        WindowStartupLocation="CenterOwner"
        Background="#F5F5F5"
        ResizeMode="CanResize">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="25,20">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#00915A" Offset="0"/>
                    <GradientStop Color="#00A566" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <StackPanel>
                <TextBlock x:Name="TxtTitle" Text="🏢 GESTION DE L'ÉQUIPE" 
                           FontSize="20" FontWeight="Bold" Foreground="White"/>
                <TextBlock x:Name="TxtSubtitle" Text="Créer ou modifier une équipe" 
                           FontSize="12" Foreground="White" Opacity="0.9" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <!-- Formulaire -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Border Background="White" Margin="20" Padding="25" CornerRadius="8">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="16" ShadowDepth="0" Opacity="0.2" Color="#D0D0D0"/>
                </Border.Effect>
                
                <StackPanel>
                    <!-- Nom -->
                    <TextBlock x:Name="LblName" Text="Nom de l'équipe *" FontSize="13" FontWeight="SemiBold" 
                               Foreground="#333" Margin="0,0,0,8"/>
                    <TextBox x:Name="TxtNom" FontSize="14" Padding="12,10" Height="40"
                             BorderBrush="#E0E0E0" BorderThickness="1" Margin="0,0,0,20"/>

                    <!-- Code -->
                    <TextBlock x:Name="LblCode" Text="Code *" FontSize="13" FontWeight="SemiBold" 
                               Foreground="#333" Margin="0,0,0,8"/>
                    <TextBox x:Name="TxtCode" FontSize="14" Padding="12,10" Height="40"
                             BorderBrush="#E0E0E0" BorderThickness="1" Margin="0,0,0,20"
                             CharacterCasing="Upper"/>

                    <!-- Description -->
                    <TextBlock x:Name="LblDescription" Text="Description" FontSize="13" FontWeight="SemiBold" 
                               Foreground="#333" Margin="0,0,0,8"/>
                    <TextBox x:Name="TxtDescription" FontSize="14" Padding="12,10" Height="60"
                             BorderBrush="#E0E0E0" BorderThickness="1" Margin="0,0,0,20"
                             TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>

                    <!-- Périmètre fonctionnel -->
                    <TextBlock x:Name="LblFunctionalScope" Text="Périmètre fonctionnel" FontSize="13" FontWeight="SemiBold" 
                               Foreground="#333" Margin="0,0,0,8"/>
                    <TextBox x:Name="TxtPerimetreFonctionnel" FontSize="14" Padding="12,10" Height="60"
                             BorderBrush="#E0E0E0" BorderThickness="1" Margin="0,0,0,20"
                             TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>

                    <!-- Manager -->
                    <TextBlock x:Name="LblManager" Text="👤 Manager de l'équipe" FontSize="13" FontWeight="SemiBold" 
                               Foreground="#333" Margin="0,0,0,8"/>
                    <ComboBox x:Name="CboManager" FontSize="14" Padding="12,10" Height="40"
                              BorderBrush="#E0E0E0" BorderThickness="1" Margin="0,0,0,5"
                              DisplayMemberPath="Display" SelectedValuePath="Id"/>
                    <TextBlock x:Name="LblManagerNote" Text="Le manager n'est pas compté dans les membres de l'équipe" 
                               FontSize="11" Foreground="#999" Margin="0,0,0,15" FontStyle="Italic"/>

                    <!-- Contact -->
                    <TextBlock x:Name="LblContact" Text="Contact (email)" FontSize="13" FontWeight="SemiBold" 
                               Foreground="#333" Margin="0,0,0,8"/>
                    <TextBox x:Name="TxtContact" FontSize="14" Padding="12,10" Height="40"
                             BorderBrush="#E0E0E0" BorderThickness="1" Margin="0,0,0,10"/>
                </StackPanel>
            </Border>
        </ScrollViewer>

        <!-- Boutons -->
        <Border Grid.Row="2" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Padding="20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Supprimer (gauche, visible uniquement en mode édition) -->
                <Button x:Name="BtnSupprimer" Grid.Column="0" Click="BtnSupprimer_Click"
                        Background="#DC3545" Foreground="White" Padding="20,10"
                        BorderThickness="0" Cursor="Hand" FontWeight="SemiBold" FontSize="14"
                        HorizontalAlignment="Left" Visibility="Collapsed">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" 
                                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#C82333"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- Annuler + Enregistrer (droite) -->
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="BtnAnnuler" Content="Annuler" Click="BtnAnnuler_Click"
                            Background="#6C757D" Foreground="White" Padding="20,10" Width="120"
                            BorderThickness="0" Cursor="Hand" FontWeight="SemiBold" FontSize="14">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" 
                                                    CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#5A6268"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button x:Name="BtnEnregistrer" Content="Enregistrer" Click="BtnEnregistrer_Click" Margin="10,0,0,0"
                            Background="#00915A" Foreground="White" Padding="20,10" Width="120"
                            BorderThickness="0" Cursor="Hand" FontWeight="SemiBold" FontSize="14">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" 
                                                    CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#007A4D"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
