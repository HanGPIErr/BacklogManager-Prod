<UserControl x:Class="BacklogManager.Views.AdministrationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="1000"
             Background="#F0F2F5">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="35,25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" CornerRadius="10" Padding="30,25" Margin="0,0,0,20">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#00915A" Offset="0"/>
                        <GradientStop Color="#00A566" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.Effect>
                    <DropShadowEffect BlurRadius="16" ShadowDepth="0" Opacity="0.2" Color="#00915A"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock FontSize="28" FontWeight="Bold" Foreground="White">
                        <Run Text="⚙️ "/>
                        <Run x:Name="TxtAdministrationTitle" Text="ADMINISTRATION"/>
                    </TextBlock>
                    <TextBlock x:Name="TxtAdministrationDescription" Text="Gestion des utilisateurs, rôles, projets et paramètres système" 
                               FontSize="14" Foreground="White" Opacity="0.9" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <!-- Tabs Navigation -->
            <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0">
                <TabControl.Resources>
                    <Style TargetType="TabItem">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TabItem">
                                    <Grid>
                                        <Border Name="Border" Background="White" BorderBrush="#E0E0E0" 
                                                BorderThickness="0,0,0,3" CornerRadius="0" 
                                                Padding="30,18" Margin="0,0,5,0">
                                            <ContentPresenter x:Name="ContentSite"
                                                              VerticalAlignment="Center"
                                                              HorizontalAlignment="Center"
                                                              ContentSource="Header"/>
                                        </Border>
                                        <Border Name="ActiveIndicator" Background="#00915A" Height="3" 
                                                VerticalAlignment="Bottom" Visibility="Collapsed"/>
                                    </Grid>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Border" Property="BorderBrush" Value="#00915A"/>
                                            <Setter TargetName="ActiveIndicator" Property="Visibility" Value="Visible"/>
                                            <Setter Property="Foreground" Value="#00915A"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="False">
                                            <Setter TargetName="Border" Property="BorderBrush" Value="#E0E0E0"/>
                                            <Setter Property="Foreground" Value="#6D6D6D"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Border" Property="Background" Value="#F5F5F5"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TabControl.Resources>

                <!-- Tab Utilisateurs & Rôles -->
                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="👥" FontSize="16" Margin="0,0,8,0"/>
                            <TextBlock x:Name="TxtUsersAndRolesTab" Text="Utilisateurs &amp; Rôles" FontSize="14"/>
                        </StackPanel>
                    </TabItem.Header>
                    <Border CornerRadius="10" Padding="30" Margin="0,10,0,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#FFFFFF" Offset="0"/>
                                <GradientStop Color="#FAFAFA" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="16" ShadowDepth="0" Opacity="0.2" Color="#D0D0D0"/>
                        </Border.Effect>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <!-- Sous-navigation avec style pill -->
                            <Border Grid.Row="0" Background="#F5F5F5" CornerRadius="25" Padding="5" Margin="0,0,0,25">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                    <Button x:Name="BtnSousOngletUtilisateurs" 
                                            Background="#00915A" Foreground="White" 
                                            FontSize="13" FontWeight="SemiBold" Padding="22,10"
                                            Margin="0" BorderThickness="0" Cursor="Hand"
                                            Click="BtnSousOngletUtilisateurs_Click">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}" 
                                                                    CornerRadius="20" Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Button.Style>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="👥" Margin="0,0,6,0"/>
                                            <TextBlock x:Name="TxtUsersSubTab" Text="Utilisateurs"/>
                                        </StackPanel>
                                    </Button>
                                    <Button x:Name="BtnSousOngletRoles" 
                                            Background="Transparent" Foreground="#6D6D6D" 
                                            FontSize="13" FontWeight="Normal" Padding="22,10"
                                            Margin="5,0,0,0" BorderThickness="0" Cursor="Hand"
                                            Click="BtnSousOngletRoles_Click">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}" 
                                                                    CornerRadius="20" Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Button.Style>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="🎭" Margin="0,0,6,0"/>
                                            <TextBlock x:Name="TxtRolesSubTab" Text="Rôles"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Border>
                            
                            <!-- Contenu dynamique -->
                            <Frame x:Name="FrameUtilisateursRoles" Grid.Row="1" NavigationUIVisibility="Hidden"/>
                        </Grid>
                    </Border>
                </TabItem>

                <!-- Tab Projets & Équipe -->
                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📊" FontSize="16" Margin="0,0,8,0"/>
                            <TextBlock x:Name="TxtProjectsAndTeamTab" Text="Projets &amp; Équipe" FontSize="14"/>
                        </StackPanel>
                    </TabItem.Header>
                    <Border CornerRadius="10" Padding="30" Margin="0,10,0,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#FFFFFF" Offset="0"/>
                                <GradientStop Color="#FAFAFA" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="16" ShadowDepth="0" Opacity="0.2" Color="#D0D0D0"/>
                        </Border.Effect>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <!-- Sous-navigation avec style pill -->
                            <Border Grid.Row="0" Background="#F5F5F5" CornerRadius="25" Padding="5" Margin="0,0,0,25">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                    <Button x:Name="BtnSousOngletProgrammes" 
                                            Background="#00915A" Foreground="White" 
                                            FontSize="13" FontWeight="SemiBold" Padding="22,10"
                                            Margin="0" BorderThickness="0" Cursor="Hand"
                                            Click="BtnSousOngletProgrammes_Click">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}" 
                                                                    CornerRadius="20" Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Button.Style>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="📊" Margin="0,0,6,0"/>
                                            <TextBlock x:Name="TxtProgramsSubTab" Text="Programmes"/>
                                        </StackPanel>
                                    </Button>
                                    <Button x:Name="BtnSousOngletProjets" 
                                            Background="Transparent" Foreground="#6D6D6D" 
                                            FontSize="13" FontWeight="Normal" Padding="22,10"
                                            Margin="5,0,0,0" BorderThickness="0" Cursor="Hand"
                                            Click="BtnSousOngletProjets_Click">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}" 
                                                                    CornerRadius="20" Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Button.Style>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="📁" Margin="0,0,6,0"/>
                                            <TextBlock x:Name="TxtProjectsSubTab" Text="Projets"/>
                                        </StackPanel>
                                    </Button>
                                    <Button x:Name="BtnSousOngletEquipes" 
                                            Background="Transparent" Foreground="#6D6D6D" 
                                            FontSize="13" FontWeight="Normal" Padding="22,10"
                                            Margin="5,0,0,0" BorderThickness="0" Cursor="Hand"
                                            Click="BtnSousOngletEquipes_Click">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}" 
                                                                    CornerRadius="20" Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Button.Style>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="🏢" Margin="0,0,6,0"/>
                                            <TextBlock x:Name="TxtTeamsSubTab" Text="Équipes"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Border>
                            
                            <!-- Contenu dynamique -->
                            <Frame x:Name="FrameProjetsEquipe" Grid.Row="1" NavigationUIVisibility="Hidden"/>
                        </Grid>
                    </Border>
                </TabItem>

                <!-- Tab Reporting & Pilotage -->
                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📈" FontSize="16" Margin="0,0,8,0"/>
                            <TextBlock x:Name="TxtReportingTab" Text="Reporting" FontSize="14"/>
                        </StackPanel>
                    </TabItem.Header>
                    <Border CornerRadius="10" Padding="0" Margin="0,10,0,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#FFFFFF" Offset="0"/>
                                <GradientStop Color="#FAFAFA" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="16" ShadowDepth="0" Opacity="0.2" Color="#D0D0D0"/>
                        </Border.Effect>
                        <Frame x:Name="FrameReporting" NavigationUIVisibility="Hidden"/>
                    </Border>
                </TabItem>

                <!-- Tab Historique Chat -->
                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="💬" FontSize="16" Margin="0,0,8,0"/>
                            <TextBlock x:Name="TxtChatHistoryTab" Text="Historique Chat IA" FontSize="14"/>
                        </StackPanel>
                    </TabItem.Header>
                    <Border CornerRadius="10" Padding="30" Margin="0,10,0,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#FFFFFF" Offset="0"/>
                                <GradientStop Color="#FAFAFA" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="16" ShadowDepth="0" Opacity="0.2" Color="#D0D0D0"/>
                        </Border.Effect>
                        <Grid>
                            <Button x:Name="BtnOuvrirHistoriqueChat" 
                                    HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Background="#00915A" Foreground="White" 
                                    FontSize="14" FontWeight="SemiBold" Padding="25,15"
                                    BorderThickness="0" Cursor="Hand"
                                    Click="BtnOuvrirHistoriqueChat_Click">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" 
                                                            CornerRadius="8" Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#00A568"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="💬" FontSize="18" Margin="0,0,10,0"/>
                                    <TextBlock x:Name="TxtOpenChatHistory" Text="Ouvrir l'historique des conversations" FontSize="14"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>
                </TabItem>

                <!-- Tab Audit -->
                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📋" FontSize="16" Margin="0,0,8,0"/>
                            <TextBlock x:Name="TxtAuditLogTab" Text="Journal d'audit" FontSize="14"/>
                        </StackPanel>
                    </TabItem.Header>
                    <Border CornerRadius="10" Padding="30" Margin="0,10,0,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#FFFFFF" Offset="0"/>
                                <GradientStop Color="#FAFAFA" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="16" ShadowDepth="0" Opacity="0.2" Color="#D0D0D0"/>
                        </Border.Effect>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <!-- Sous-navigation avec style pill -->
                            <Border Grid.Row="0" Background="#F5F5F5" CornerRadius="25" Padding="5" Margin="0,0,0,25">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                    <Button x:Name="BtnSousOngletAuditLog" 
                                            Background="#00915A" Foreground="White" 
                                            FontSize="13" FontWeight="SemiBold" Padding="22,10"
                                            Margin="0" BorderThickness="0" Cursor="Hand"
                                            Click="BtnSousOngletAuditLog_Click">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}" 
                                                                    CornerRadius="20" Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Button.Style>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="📋" Margin="0,0,6,0"/>
                                            <TextBlock x:Name="TxtAuditLogSubTab" Text="Journal d'audit"/>
                                        </StackPanel>
                                    </Button>
                                    <Button x:Name="BtnSousOngletAuditStats" 
                                            Background="Transparent" Foreground="#6D6D6D" 
                                            FontSize="13" FontWeight="Normal" Padding="22,10"
                                            Margin="5,0,0,0" BorderThickness="0" Cursor="Hand"
                                            Click="BtnSousOngletAuditStats_Click">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}" 
                                                                    CornerRadius="20" Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Button.Style>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="📊" Margin="0,0,6,0"/>
                                            <TextBlock x:Name="TxtAuditStatsSubTab" Text="Statistiques"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Border>
                            
                            <!-- Contenu dynamique -->
                            <Frame x:Name="FrameAudit" Grid.Row="1" NavigationUIVisibility="Hidden"/>
                        </Grid>
                    </Border>
                </TabItem>

                <!-- Tab Configuration IA -->
                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🤖" FontSize="16" Margin="0,0,8,0"/>
                            <TextBlock x:Name="TxtAIConfigTab" Text="Configuration IA" FontSize="14"/>
                        </StackPanel>
                    </TabItem.Header>
                    <Border CornerRadius="10" Padding="30" Margin="0,10,0,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#FFFFFF" Offset="0"/>
                                <GradientStop Color="#FAFAFA" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="16" ShadowDepth="0" Opacity="0.2" Color="#D0D0D0"/>
                        </Border.Effect>
                        <StackPanel>
                            <!-- Titre section -->
                            <TextBlock x:Name="TxtAIConfigTitle" Text="🤖 Configuration de l'Intelligence Artificielle" 
                                       FontSize="20" FontWeight="Bold" 
                                       Foreground="#1A1919" Margin="0,0,0,10"/>
                            <TextBlock x:Name="TxtAIConfigDescription" 
                                       Text="Gérez le token d'authentification pour les appels à l'API IA"
                                       FontSize="13" Foreground="#6D6D6D" Margin="0,0,0,15"/>

                            <!-- Bandeau d'avertissement -->
                            <Border Background="#FFF8E1" BorderBrush="#FFB300" BorderThickness="1"
                                    CornerRadius="8" Padding="15,12" Margin="0,0,0,20">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⚠️" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Top"/>
                                    <TextBlock x:Name="TxtAIConfigWarning"
                                               FontSize="12" Foreground="#5D4037"
                                               TextWrapping="Wrap" VerticalAlignment="Center"
                                               Text="Ces paramètres sont préconfigurés pour l'environnement de production. Ne les modifiez que si vous êtes certain de l'impact : toute erreur de configuration peut entraîner l'arrêt complet des fonctionnalités IA dans l'application."/>
                                </StackPanel>
                            </Border>

                            <!-- URL API (lecture seule) -->
                            <Border Background="#F8F9FA" CornerRadius="8" Padding="20" Margin="0,0,0,15">
                                <StackPanel>
                                    <TextBlock x:Name="LblApiUrl" Text="URL de l'API" FontWeight="SemiBold" Foreground="#1A1919" Margin="0,0,0,8"/>
                                    <TextBox x:Name="TxtAPIUrl" 
                                             IsReadOnly="True" 
                                             BorderThickness="0"
                                             Background="Transparent"
                                             Foreground="#6D6D6D"
                                             FontSize="12"
                                             TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <!-- Modèle IA (lecture seule) -->
                            <Border Background="#F8F9FA" CornerRadius="8" Padding="20" Margin="0,0,0,15">
                                <StackPanel>
                                    <TextBlock x:Name="LblAIModel" Text="Modèle IA" FontWeight="SemiBold" Foreground="#1A1919" Margin="0,0,0,8"/>
                                    <TextBox x:Name="TxtAIModel" 
                                             IsReadOnly="True" 
                                             BorderThickness="0"
                                             Background="Transparent"
                                             Foreground="#6D6D6D"
                                             FontSize="12"/>
                                </StackPanel>
                            </Border>

                            <!-- Token API (modifiable) -->
                            <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1" 
                                    CornerRadius="8" Padding="20" Margin="0,0,0,20">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <TextBlock x:Name="LblTokenAPI" Text="Token API" FontWeight="SemiBold" Foreground="#1A1919"/>
                                        <TextBlock Text=" *" Foreground="#D32F2F"/>
                                    </StackPanel>
                                    <TextBox x:Name="TxtAPIToken" 
                                             Height="100"
                                             TextWrapping="Wrap"
                                             AcceptsReturn="True"
                                             VerticalScrollBarVisibility="Auto"
                                             BorderBrush="#D0D0D0"
                                             BorderThickness="1"
                                             Padding="10"
                                             FontSize="11"
                                             FontFamily="Consolas"
                                             Foreground="#1A1919"/>
                                    <TextBlock x:Name="TxtTokenHelp" 
                                               Text="Collez ici le token JWT complet obtenu depuis GenFactory"
                                               FontSize="11" Foreground="#6D6D6D" 
                                               Margin="0,8,0,0" FontStyle="Italic"/>
                                </StackPanel>
                            </Border>

                            <!-- Statut du token -->
                            <Border x:Name="BorderTokenStatus" 
                                    Background="#E8F5E9" BorderBrush="#4CAF50" BorderThickness="1"
                                    CornerRadius="8" Padding="15" Margin="0,0,0,20" Visibility="Collapsed">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="TxtTokenStatusIcon" Text="✓" FontSize="16" 
                                               Foreground="#4CAF50" Margin="0,0,10,0"/>
                                    <TextBlock x:Name="TxtTokenStatus" 
                                               Text="Token configuré et valide" 
                                               FontSize="13" Foreground="#2E7D32"/>
                                </StackPanel>
                            </Border>

                            <!-- Boutons d'action -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button x:Name="BtnTestToken" 
                                        Content="🔍 Tester le token"
                                        Background="White" Foreground="#00915A"
                                        BorderBrush="#00915A" BorderThickness="2"
                                        FontSize="14" FontWeight="SemiBold" 
                                        Padding="20,12" Margin="0,0,10,0"
                                        Cursor="Hand" Click="BtnTestToken_Click">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" 
                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#F0F8F5"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button x:Name="BtnSaveToken" 
                                        Content="💾 Enregistrer"
                                        Background="#00915A" Foreground="White"
                                        FontSize="14" FontWeight="SemiBold" 
                                        Padding="25,12" Cursor="Hand"
                                        Click="BtnSaveToken_Click">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" 
                                                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#007A4D"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </TabItem>

                <!-- Tab Test Unitaire Sync -->
                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🧪" FontSize="16" Margin="0,0,8,0"/>
                            <TextBlock Text="Test Unitaire" FontSize="14"/>
                        </StackPanel>
                    </TabItem.Header>
                    <Border CornerRadius="10" Padding="30" Margin="0,10,0,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#FFFFFF" Offset="0"/>
                                <GradientStop Color="#FAFAFA" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="16" ShadowDepth="0" Opacity="0.2" Color="#D0D0D0"/>
                        </Border.Effect>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Titre -->
                            <TextBlock Grid.Row="0" Text="🧪 Test d'intégration multi-utilisateur (Synchronisation)" 
                                       FontSize="20" FontWeight="Bold" 
                                       Foreground="#1A1919" Margin="0,0,0,10"/>
                            <TextBlock Grid.Row="1" 
                                       Text="Lance un scénario de test complet sur 2 postes simultanés. Crée des utilisateurs, projets, demandes, backlog items, CRA, commentaires, etc. puis vérifie que toutes les données sont synchronisées entre les postes."
                                       FontSize="13" Foreground="#6D6D6D" Margin="0,0,0,15" TextWrapping="Wrap"/>

                            <!-- Bandeau d'info -->
                            <Border Grid.Row="2" Background="#E3F2FD" BorderBrush="#1976D2" BorderThickness="1"
                                    CornerRadius="8" Padding="15,12" Margin="0,0,0,20">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="ℹ️" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Top"/>
                                    <TextBlock FontSize="12" Foreground="#1565C0" TextWrapping="Wrap" VerticalAlignment="Center"
                                               Text="Ce test doit être lancé simultanément sur 2 postes. Les 2 postes s'attendent mutuellement (timeout 2 min). Ensuite, chaque poste crée ~36 entités de test préfixées par son ClientId. Après synchronisation, le script vérifie que toutes les entités des 2 postes sont présentes dans chaque base locale."/>
                                </StackPanel>
                            </Border>

                            <!-- Boutons + barre de progression -->
                            <StackPanel Grid.Row="3" Margin="0,0,0,15">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <Button x:Name="BtnLancerTest" Content="🚀 Lancer le test"
                                            Background="#00915A" Foreground="White"
                                            FontSize="14" FontWeight="SemiBold" 
                                            Padding="25,12" Cursor="Hand"
                                            Click="BtnLancerTest_Click">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}" 
                                                                    CornerRadius="8" Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#007A4D"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button x:Name="BtnAnnulerTest" Content="⏹ Annuler"
                                            Background="#D32F2F" Foreground="White"
                                            FontSize="14" FontWeight="SemiBold" 
                                            Padding="20,12" Margin="10,0,0,0" Cursor="Hand"
                                            IsEnabled="False"
                                            Click="BtnAnnulerTest_Click">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}" 
                                                                    CornerRadius="8" Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <TextBlock x:Name="TxtTestStatus" Text="" FontSize="14" Foreground="#6D6D6D"
                                               VerticalAlignment="Center" Margin="15,0,0,0"/>
                                </StackPanel>
                                <ProgressBar x:Name="ProgressTest" Height="8" Minimum="0" Maximum="100" Value="0"
                                             Foreground="#00915A" Background="#E0E0E0" Margin="0,0,0,5"/>
                            </StackPanel>

                            <!-- Log en temps réel -->
                            <Border Grid.Row="4" Background="#1A1919" CornerRadius="8" Padding="15"
                                    MinHeight="300" MaxHeight="500">
                                <ScrollViewer x:Name="ScrollTestLog" VerticalScrollBarVisibility="Auto">
                                    <TextBlock x:Name="TxtTestLog" Text="En attente du lancement du test..."
                                               FontFamily="Consolas" FontSize="12" Foreground="#C0C0C0"
                                               TextWrapping="Wrap"/>
                                </ScrollViewer>
                            </Border>
                        </Grid>
                    </Border>
                </TabItem>
            </TabControl>
        </Grid>
    </ScrollViewer>
</UserControl>
