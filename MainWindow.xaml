<Window x:Class="BacklogManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:BacklogManager.Views"
        xmlns:vm="clr-namespace:BacklogManager.ViewModels"
        xmlns:services="clr-namespace:BacklogManager.Services"
        Title="BNP Paribas - ORBITT" Height="850" Width="1300"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5"
        Icon="/Images/backlogmanager.ico">
    
    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:ProjetsViewModel}">
            <views:ProjetsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:BacklogViewModel}">
            <views:BacklogView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:KanbanViewModel}">
            <views:KanbanView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:PokerViewModel}">
            <views:PokerView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:TimelineViewModel}">
            <views:TimelineView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ArchivesViewModel}">
            <views:ArchivesView/>
        </DataTemplate>
        
        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,18"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                Padding="{TemplateBinding Padding}"
                                BorderThickness="0,0,4,0"
                                BorderBrush="Transparent">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#007A4D"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#006341"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left Menu with BNP Branding -->
        <Border Grid.Column="0" Background="#1A1919" Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- BNP Header (fixe en haut) -->
                <Border Grid.Row="0" Background="#00915A" Padding="20,25">
                    <StackPanel>
                        <Image Source="/Images/logobnp.png" Height="40" Width="180" 
                               Stretch="Uniform" HorizontalAlignment="Left" Margin="0,0,0,8"/>
                        <TextBlock Text="ORBITT" FontSize="13" FontWeight="SemiBold"
                                   Foreground="White" Margin="0,0,0,2" Opacity="0.95"/>
                        <TextBlock Text="(Operation Ressources, Budget &amp; report," FontSize="8" 
                                   Foreground="White" Margin="0,0,0,0" Opacity="0.7" TextWrapping="Wrap"/>
                        <TextBlock Text="Industrialisation Tracking)" FontSize="8" 
                                   Foreground="White" Margin="0,0,0,0" Opacity="0.7"/>
                    </StackPanel>
                </Border>

                <!-- Menu avec scroll -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" 
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <!-- Utilisateur connecté (compact) -->
                        <Border Background="#2A2A2A" Padding="12,10" Margin="15,15,15,0" CornerRadius="4">
                            <StackPanel>
                                <TextBlock x:Name="TxtUtilisateurConnecte" Text="👤 Han GP" 
                                           Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                                <TextBlock x:Name="TxtRoleUtilisateur" Text="📊 Développeur" 
                                           Foreground="#999999" FontSize="10" Margin="0,2,0,0"/>
                                <Button Content="🔄 Changer d'utilisateur" Margin="0,8,0,0" 
                                        x:Name="BtnChangerUtilisateurMenu"
                                        Padding="8,4" FontSize="10" 
                                        Background="#00915A" Foreground="White" 
                                        BorderThickness="0" Cursor="Hand"
                                        Click="BtnChangerUtilisateur_Click"/>
                            </StackPanel>
                        </Border>

                        <!-- SECTION : VUES -->
                        <TextBlock x:Name="TxtHeaderVues" FontSize="10" FontWeight="Bold" 
                                   Foreground="#666666" Margin="20,25,0,8" Opacity="0.7"/>

                        <Button x:Name="BtnDashboard"
                                Style="{StaticResource MenuButtonStyle}" Margin="0,0,0,0"
                                Click="BtnDashboard_Click"/>

                        <Button x:Name="BtnBacklog"
                                Style="{StaticResource MenuButtonStyle}" Margin="0,4,0,0"
                                Click="BtnBacklog_Click"/>
                        
                        <Button x:Name="BtnKanban"
                                Style="{StaticResource MenuButtonStyle}" Margin="0,4,0,0"
                                Click="BtnKanban_Click"/>

                        <!-- SECTION : TEMPS & CRA -->
                        <TextBlock x:Name="TxtHeaderTimeAndCRA" FontSize="10" FontWeight="Bold" 
                                   Foreground="#666666" Margin="20,20,0,8" Opacity="0.7"/>

                        <Button x:Name="BtnSaisirCRA" 
                                Style="{StaticResource MenuButtonStyle}" Margin="0,0,0,0"
                                Click="BtnSaisirCRA_Click"/>

                        <!-- SECTION : ADMIN -->
                        <TextBlock x:Name="AdminSectionTitle" FontSize="10" FontWeight="Bold" 
                                   Foreground="#666666" Margin="20,20,0,8" Opacity="0.7"/>

                        <Button x:Name="BtnTimeline"
                                Style="{StaticResource MenuButtonStyle}" Margin="0,0,0,0"
                                Click="BtnTimeline_Click"/>

                        <!-- SECTION : ACTIONS -->
                        <TextBlock x:Name="TxtHeaderActions" FontSize="10" FontWeight="Bold" 
                                   Foreground="#666666" Margin="20,20,0,8" Opacity="0.7"/>

                        <Button x:Name="BtnDemandes" 
                                Style="{StaticResource MenuButtonStyle}" Margin="0,0,0,0"
                                Click="BtnDemandes_Click"/>

                        <!-- Notifications avec badge -->
                        <Grid Margin="0,4,0,0">
                            <Button x:Name="BtnNotifications" 
                                    Style="{StaticResource MenuButtonStyle}"
                                    Click="BtnNotifications_Click"/>
                            <Border x:Name="BadgeNotifications" Background="#D32F2F" CornerRadius="10" 
                                    Padding="6,2" Margin="0,5,15,0" HorizontalAlignment="Right" VerticalAlignment="Top"
                                    Visibility="Collapsed">
                                <TextBlock x:Name="TxtBadgeCount" Text="0" FontSize="10" FontWeight="Bold" 
                                           Foreground="White" HorizontalAlignment="Center"/>
                            </Border>
                        </Grid>

                        <!-- SECTION : ADMINISTRATION -->
                        <TextBlock x:Name="TxtHeaderAdmin" FontSize="10" FontWeight="Bold" 
                                   Foreground="#666666" Margin="20,20,0,8" Opacity="0.7"/>

                        <Button x:Name="BtnAdmin" 
                                Style="{StaticResource MenuButtonStyle}" Margin="0,0,0,0"
                                Click="BtnAdmin_Click"/>
                        
                        <Button x:Name="BtnStatistiques" 
                                Style="{StaticResource MenuButtonStyle}" Margin="0,4,0,0"
                                Click="BtnStatistiques_Click"/>
                        
                        <Button x:Name="BtnParametres" 
                                Style="{StaticResource MenuButtonStyle}" Margin="0,4,0,0"
                                Click="BtnParametres_Click"/>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <Border Grid.Column="1" Background="White">
            <ContentControl x:Name="MainContentControl" Content="{Binding CurrentView}"/>
        </Border>
    </Grid>
</Window>
